fn is_valid(val) {
    if val == null {
        return 0
    } else {
        return 1
    }
}

fn main() {
    let mut count = 0
    for let mut i = 0; i < 500000; i = i + 1 {
        let mut val = null

        if i % 2 == 0 {
            val = i
        }
        count = count + is_valid(val)
    }
    print(count)
}

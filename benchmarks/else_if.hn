fn classify(n) {
    if n < 0 {
        return -1
    } else if n == 0 {
        return 0
    } else if n < 10 {
        return 1
    } else if n < 100 {
        return 2
    } else {
        return 3
    }
}

fn main() {
    let sum = 0
    for let i = 0; i < 100000; i = i + 1 {
        sum = sum + classify(i % 200)
    }
    print(sum)
}

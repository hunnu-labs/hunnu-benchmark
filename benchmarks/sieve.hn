fn is_prime(n) {
    if n <= 1 {
        return 0
    }
    if n == 2 {
        return 1
    }
    if n % 2 == 0 {
        return 0
    }
    for let i = 3; i * i <= n; i = i + 2 {
        if n % i == 0 {
            return 0
        }
    }
    return 1
}

fn main() {
    let count = 0
    for let i = 2; i < 1000; i = i + 1 {
        if is_prime(i) == 1 {
            count = count + 1
        }
    }
    print(count)
}